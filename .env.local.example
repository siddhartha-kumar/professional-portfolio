# ────────────────────────────────────────────────────────────────────
# Local environment variables. Copy to .env.local and fill in.
# Do NOT commit .env.local — it's gitignored.
# ────────────────────────────────────────────────────────────────────

# Optional: GitHub Personal Access Token
# Without this, the GitHub section uses the unauthenticated rate limit
# (60 req/hr per IP). With a token (any classic PAT, no scopes needed),
# you get 5,000 req/hr — recommended for production.
# Generate: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Production site URL (used in metadata, sitemap, robots)
# NEXT_PUBLIC_SITE_URL=https://siddharthakumar.dev
